# === Supabase ===
# Findest du im Supabase-Dashboard unter: Project Settings -> API
# Diese Datei ist nur die Vorlage. Kopiere sie zu ".env.local" und trage die echten Werte ein.

# Project URL (z. B. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon key (oeffentlich, darf im Browser landen)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key (GEHEIM! Nur serverseitig, niemals im Browser, niemals committen)
SUPABASE_SERVICE_ROLE_KEY=

# === Telegram (ab Meilenstein 3) ===
# TELEGRAM_BOT_TOKEN=

# === Claude API (ab Meilenstein 4) ===
# ANTHROPIC_API_KEY=
